# API Server Configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173

# =============================================================================
# Database Configuration (Prisma with SQLite)
# =============================================================================

# SQLite Database (file-based)
DATABASE_URL="file:./data/spectree.db"

# =============================================================================
# JWT Configuration
# =============================================================================

# Secret key for signing JWT tokens (use a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# =============================================================================
# Pre-Flight Checklist Thresholds (ENG-E217)
# =============================================================================

# Minimum tasks required per feature for the Task Density check (default: 3)
PREFLIGHT_MIN_TASKS_PER_FEATURE=3

# Minimum acceptance criteria required per feature (default: 3)
PREFLIGHT_MIN_ACCEPTANCE_CRITERIA=3

# Minimum epic description quality score (0-100) to pass the Epic Description check (default: 95)
PREFLIGHT_MIN_DESCRIPTION_SCORE=95
